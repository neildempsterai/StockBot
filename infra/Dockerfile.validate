# Release gate validation: migrations, DB tests, replay. No host venv required.
# Run with compose.test.yaml; repo is mounted at /app so scripts/replay/artifacts are available.
FROM python:3.11-slim
WORKDIR /app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH=/app:/app/src

# Install project + dev deps (alembic, pytest, etc.)
COPY pyproject.toml ./
COPY src/ ./src/
RUN pip install --no-cache-dir -e ".[dev]"

# Entrypoint runs release gate; repo (migrations, replay, scripts) mounted at /app by compose
CMD ["bash", "-c", "scripts/release_gate.sh --docker-inner"]
